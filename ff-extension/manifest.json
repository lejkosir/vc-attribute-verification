{
  "manifest_version": 2,
  "name": "VC Wallet Firefox Extension",
  "version": "1.0",
  "description": "Detect VC div and request wallet",
  "permissions": [
    "tabs",
    "activeTab",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}